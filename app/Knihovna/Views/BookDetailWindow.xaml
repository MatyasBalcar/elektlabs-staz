<Window
    x:Class="Knihovna.Views.BookDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Detail Autora"
    Style="{StaticResource BookDetailWindow}"
    WindowStartupLocation="CenterOwner">

    <DockPanel Margin="20">
        <StackPanel
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Width="100"
                Height="30"
                Command="{Binding CloseCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                Content="Zavřít"
                IsCancel="True"
                Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">

                <TextBlock
                    Margin="0,0,0,15"
                    FontSize="26"
                    FontWeight="Bold"
                    Text="{Binding CurrentBook.Name}"
                    TextWrapping="Wrap" />

                <Label
                    Padding="0,0,0,2"
                    Content="Autor:"
                    FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding CurrentBook.Authors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,2,0,5"
                                FontSize="16"
                                Text="{Binding FullName}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,10" Background="LightGray" />

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Label
                            Padding="0"
                            Content="Vydavatel:"
                            FontWeight="SemiBold" />
                        <TextBlock Margin="0,2,0,10" Text="{Binding CurrentBook.Publisher.Name}" />

                        <Label
                            Padding="0"
                            Content="ISBN:"
                            FontWeight="SemiBold" />
                        <TextBlock Margin="0,2,0,10" Text="{Binding CurrentBook.ISBN}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Label
                            Padding="0"
                            Content="Jazyk:"
                            FontWeight="SemiBold" />
                        <TextBlock Margin="0,2,0,10" Text="{Binding CurrentBook.Language.Name}" />

                        <Label
                            Padding="0"
                            Content="Datum vydání:"
                            FontWeight="SemiBold" />
                        <TextBlock Margin="0,2,0,10" Text="{Binding CurrentBook.PublishDate, StringFormat=d}" />
                    </StackPanel>
                </Grid>

                <Separator Margin="0,10" Background="LightGray" />

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <Label
                            Padding="0"
                            Content="Hodnocení:"
                            FontWeight="SemiBold" />
                        <TextBlock
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="Gold"
                            Text="{Binding CurrentBook.Rating, Converter={StaticResource RatingToStarsConverter}}">
                            <TextBlock.Effect>
                                <DropShadowEffect
                                    BlurRadius="5"
                                    Opacity="0.5"
                                    ShadowDepth="1"
                                    Color="Black" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Label
                    Padding="0,15,0,2"
                    Content="Popis:"
                    FontWeight="SemiBold" />
                <TextBlock
                    Margin="0,0,0,25"
                    LineHeight="20"
                    Text="{Binding CurrentBook.Description}"
                    TextWrapping="Wrap" />



            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>