<Window
    x:Class="Knihovna.Views.AuthorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.Style>
        <StaticResource ResourceKey="AuthorWindow" />
    </Window.Style>

    <DockPanel Margin="20">
        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="25"
                Click="Save_Click"
                Content="Uložit"
                IsDefault="True"
                Style="{StaticResource SuccessButtonStyle}" />
            <Button
                Width="80"
                Height="25"
                Margin="10,0,0,0"
                Content="Zrušit"
                IsCancel="True"
                Style="{StaticResource DangerButtonOutlineStyle}" />
        </StackPanel>

        <ScrollViewer BorderThickness="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">

                <Label Content="Jméno:" Style="{StaticResource RequiredLabelStyle}" />
                <TextBox Text="{Binding CurrentAuthor.FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label Content="Příjmení:" Style="{StaticResource RequiredLabelStyle}" />
                <TextBox Text="{Binding CurrentAuthor.LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label Content="Datum narození:" FontWeight="SemiBold" />
                <DatePicker
                    Foreground="Black"
                    SelectedDate="{Binding CurrentAuthor.DateOfBirth}"
                    Style="{StaticResource RoundedDatePickerStyle}" />

                <StackPanel Margin="0,10,0,0">
                    <Label Content="Národnost:" Style="{StaticResource RequiredLabelStyle}" />
                    <Grid>
                        <TextBox x:Name="NationalityTextBox" Text="{Binding NationalityText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsSuggestionsVisible}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=NationalityTextBox}"
                            PopupAnimation="Slide"
                            StaysOpen="False">
                            <ListBox
                                MinWidth="{Binding ActualWidth, ElementName=NationalityTextBox}"
                                MaxHeight="150"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding SuggestedNationalities}"
                                SelectionChanged="ListBox_SelectionChanged">
                                <ListBox.Style>
                                    <Style BasedOn="{StaticResource {x:Type ListBox}}" TargetType="ListBox">
                                        <Style.Triggers>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                            </ListBox>
                        </Popup>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>