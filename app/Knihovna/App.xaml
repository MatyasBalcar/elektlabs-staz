<Application
    x:Class="Knihovna.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Knihovna.Converters"
    xmlns:local="clr-namespace:Knihovna"
    xmlns:vm="clr-namespace:Knihovna.ViewModels"
    StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>

            <conv:RatingToStarsConverter x:Key="RatingToStarsConverter" />

            <conv:RatingToColorConverter x:Key="RatingToColorConverter" />


            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/ComponentStyles.xaml" />
                <ResourceDictionary Source="Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="Styles/AppStyles.xaml" />
                <ResourceDictionary Source="Styles/Templates.xaml" />

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>