<Window
    x:Class="Knihovna.Views.BookWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Knihovna.Helpers"
    Style="{StaticResource BookWindow}"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel Margin="10">
        <StackPanel Margin="0,10,0,0" DockPanel.Dock="Bottom">
            <Button
                Height="30"
                Click="Save_Click"
                Content="Uložit"
                IsDefault="True"
                Style="{StaticResource SuccessButtonStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Height="30"
                    Command="{Binding AddAuthorCommand}"
                    Content="Nový autor"
                    Style="{StaticResource SecondaryButtonStyle}" />
                <Button
                    Grid.Column="1"
                    Height="30"
                    Content="Zrušit"
                    IsCancel="True"
                    Style="{StaticResource DangerButtonOutlineStyle}" />
            </Grid>
        </StackPanel>

        <ScrollViewer Padding="0,0,5,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Label Content="Název knihy:" Style="{StaticResource RequiredLabelStyle}" />
                <TextBox Text="{Binding EditingBook.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label
                    Content="ISBN:"
                    Style="{StaticResource InfoLabelStyle}"
                    Tag="ISBN je číslo o délce od 10 do 13 číslic, pomlčky a mezery jsou povoleny" />
                <TextBox Text="{Binding EditingBook.ISBN, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

                <Label Content="Autor:" Style="{StaticResource RequiredLabelStyle}" />
                <ComboBox
                    helpers:ComboBoxFilterHelper.IsSearchable="True"
                    DisplayMemberPath="FullName"
                    FontWeight="Light"
                    ItemsSource="{Binding AllAuthors}"
                    SelectedItem="{Binding SelectedAuthor}" />

                <StackPanel>
                    <Label Content="Jazyk:" Style="{StaticResource RequiredLabelStyle}" />
                    <Grid>
                        <TextBox x:Name="LanguageTextBox" Text="{Binding LanguageText, UpdateSourceTrigger=PropertyChanged}" />

                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsLangSuggestionsVisible}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=LanguageTextBox}"
                            PopupAnimation="Slide"
                            StaysOpen="False">
                            <ListBox
                                MinWidth="{Binding ActualWidth, ElementName=LanguageTextBox}"
                                MaxHeight="150"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding SuggestedLanguages}"
                                SelectionChanged="Lang_SelectionChanged" />
                        </Popup>
                    </Grid>
                </StackPanel>

                <StackPanel>
                    <Label Content="Vydavatel:" Style="{StaticResource RequiredLabelStyle}" />
                    <Grid>
                        <TextBox x:Name="PublisherTextBox" Text="{Binding PublisherText, UpdateSourceTrigger=PropertyChanged}" />

                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsPubSuggestionsVisible}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=PublisherTextBox}"
                            PopupAnimation="Slide"
                            StaysOpen="False">
                            <ListBox
                                MinWidth="{Binding ActualWidth, ElementName=PublisherTextBox}"
                                MaxHeight="150"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding SuggestedPublishers}"
                                SelectionChanged="Pub_SelectionChanged" />
                        </Popup>
                    </Grid>
                </StackPanel>

                <Label Content="Datum vydání:" FontWeight="SemiBold" />
                <DatePicker
                    Foreground="Black"
                    SelectedDate="{Binding EditingBook.PublishDate}"
                    Style="{StaticResource RoundedDatePickerStyle}" />

                <Label Content="Popis:" FontWeight="SemiBold" />
                <TextBox
                    MinHeight="80"
                    VerticalContentAlignment="Top"
                    Text="{Binding EditingBook.Description}"
                    TextWrapping="Wrap" />

                <StackPanel
                    Margin="0,15,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Content="Přečteno:"
                        FontWeight="SemiBold" />

                    <CheckBox
                        Content="{x:Null}"
                        IsChecked="{Binding EditingBook.HaveRead}"
                        Style="{StaticResource Switch}" />
                </StackPanel>

                <StackPanel
                    Margin="0,15,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Margin="0,10,0,0"
                        Content="Hodnocení:"
                        FontWeight="SemiBold" />
                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                        <Button
                            Command="{Binding SetRatingCommand}"
                            CommandParameter="1"
                            Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=1}"
                            Style="{StaticResource StarButtonStyle}" />
                        <Button
                            Command="{Binding SetRatingCommand}"
                            CommandParameter="2"
                            Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=2}"
                            Style="{StaticResource StarButtonStyle}" />
                        <Button
                            Command="{Binding SetRatingCommand}"
                            CommandParameter="3"
                            Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=3}"
                            Style="{StaticResource StarButtonStyle}" />
                        <Button
                            Command="{Binding SetRatingCommand}"
                            CommandParameter="4"
                            Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=4}"
                            Style="{StaticResource StarButtonStyle}" />
                        <Button
                            Command="{Binding SetRatingCommand}"
                            CommandParameter="5"
                            Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=5}"
                            Style="{StaticResource StarButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>