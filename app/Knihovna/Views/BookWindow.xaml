<Window
    x:Class="Knihovna.Views.BookWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Style="{StaticResource BookWindow}"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel Margin="10">
        <StackPanel Margin="0,10,0,0" DockPanel.Dock="Bottom">
            <Button
                Height="30"
                Click="Save_Click"
                Content="Uložit"
                IsDefault="True"
                Style="{StaticResource SuccessButtonStyle}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Height="30"
                    Command="{Binding AddAuthorCommand}"
                    Content="Nový autor"
                    Style="{StaticResource SecondaryButtonStyle}" />
                <Button
                    Grid.Column="1"
                    Height="30"
                    Content="Zrušit"
                    IsCancel="True"
                    Style="{StaticResource DangerButtonOutlineStyle}" />
            </Grid>
        </StackPanel>

        <ScrollViewer Padding="0,0,5,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Label Content="Název knihy:" FontWeight="SemiBold" />
                <TextBox Text="{Binding EditingBook.Name}" />

                <Label
                    Margin="0,10,0,0"
                    Content="ISBN:"
                    FontWeight="SemiBold" />
                <TextBox Text="{Binding EditingBook.ISBN}" />

                <Label
                    Margin="0,10,0,0"
                    Content="Popis:"
                    FontWeight="SemiBold" />
                <TextBox
                    MinHeight="80"
                    VerticalContentAlignment="Top"
                    Text="{Binding EditingBook.Description}"
                    TextWrapping="Wrap" />

                <Label
                    Margin="0,10,0,0"
                    Content="Autor:"
                    FontWeight="SemiBold" />
                <ComboBox
                    DisplayMemberPath="FullName"
                    ItemsSource="{Binding AllAuthors}"
                    SelectedItem="{Binding SelectedAuthor}" />

                <StackPanel Margin="0,10,0,0">
                    <Label Content="Jazyk:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding LanguageText, UpdateSourceTrigger=PropertyChanged}" />
                    <ListBox
                        MaxHeight="80"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding SuggestedLanguages}"
                        SelectionChanged="Lang_SelectionChanged"
                        Visibility="{Binding IsLangSuggestionsVisible, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <StackPanel Margin="0,10,0,0">
                    <Label Content="Vydavatel:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding PublisherText, UpdateSourceTrigger=PropertyChanged}" />
                    <ListBox
                        MaxHeight="80"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding SuggestedPublishers}"
                        SelectionChanged="Pub_SelectionChanged"
                        Visibility="{Binding IsPubSuggestionsVisible, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <Label
                    Margin="0,10,0,0"
                    Content="Datum vydání:"
                    FontWeight="SemiBold" />
                <DatePicker
                    Foreground="Black"
                    SelectedDate="{Binding EditingBook.PublishDate}"
                    Style="{StaticResource RoundedDatePickerStyle}" />

                <Label
                    Margin="0,10,0,0"
                    Content="Hodnocení:"
                    FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal">
                    <Button
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="1"
                        Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=1}"
                        Style="{StaticResource StarButtonStyle}" />
                    <Button
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="2"
                        Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=2}"
                        Style="{StaticResource StarButtonStyle}" />
                    <Button
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="3"
                        Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=3}"
                        Style="{StaticResource StarButtonStyle}" />
                    <Button
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="4"
                        Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=4}"
                        Style="{StaticResource StarButtonStyle}" />
                    <Button
                        Command="{Binding SetRatingCommand}"
                        CommandParameter="5"
                        Foreground="{Binding EditingBook.Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=5}"
                        Style="{StaticResource StarButtonStyle}" />
                </StackPanel>

                <CheckBox
                    Margin="0,10"
                    Content="Přečteno"
                    FontWeight="SemiBold"
                    IsChecked="{Binding EditingBook.HaveRead}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>