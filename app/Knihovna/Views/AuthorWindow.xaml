<Window
    x:Class="Knihovna.Views.AuthorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.Style>
        <StaticResource ResourceKey="AuthorWindow" />
    </Window.Style>

    <DockPanel Margin="20">
        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="25"
                Click="Save_Click"
                Content="Uložit"
                IsDefault="True"
                Style="{StaticResource SuccessButtonStyle}" />
            <Button
                Width="80"
                Height="25"
                Margin="10,0,0,0"
                Content="Zrušit"
                IsCancel="True"
                Style="{StaticResource DangerButtonOutlineStyle}" />
        </StackPanel>

        <ScrollViewer BorderThickness="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <Label Content="Jméno:" FontWeight="SemiBold" />
                <TextBox Text="{Binding CurrentAuthor.FirstName}" />

                <Label
                    Margin="0,10,0,0"
                    Content="Příjmení:"
                    FontWeight="SemiBold" />
                <TextBox Text="{Binding CurrentAuthor.LastName}" />

                <Label
                    Margin="0,10,0,0"
                    Content="Datum narození:"
                    FontWeight="SemiBold" />
                <DatePicker
                    Foreground="Black"
                    SelectedDate="{Binding CurrentAuthor.DateOfBirth}"
                    Style="{StaticResource RoundedDatePickerStyle}" />

                <StackPanel Margin="0,10,0,0">
                    <Label Content="Národnost:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding NationalityText, UpdateSourceTrigger=PropertyChanged}" />

                    <ListBox
                        MaxHeight="100"
                        d:ItemsSource="{d:SampleData ItemCount=5}"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding SuggestedNationalities}"
                        SelectionChanged="ListBox_SelectionChanged"
                        Visibility="{Binding IsSuggestionsVisible, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>